<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.scnu.mapper.bus.BusCategoryMapper">

    <sql id="Base_Column_List">
        id,name,img,descr,content,service_type
    </sql>

    <select id="selectAll" resultType="com.scnu.entity.bus.BusCategory">
        select
        <include refid="Base_Column_List" />
        from bus_category
        <where>
            <if test="name != null"> and name like concat('%', #{name}, '%')</if>
            <if test="serviceType != null and serviceType != ''">
                and service_type = #{serviceType}</if>
        </where>
        order by id
    </select>


    <select id="selectTop" resultType="com.scnu.entity.bus.BusCategory">
        select
        <include refid="Base_Column_List" />
        from bus_category
        <where>
            <if test="serviceType != null and serviceType != ''">
                service_type = #{serviceType}
            </if>
        </where>
        order by id desc
        limit 8
    </select>

    <select id="selectById" resultType="com.scnu.entity.bus.BusCategory">
        select
        <include refid="Base_Column_List" />
        from bus_category
        where id = #{id}
    </select>

    <delete id="deleteById">
        delete from bus_category
        where  id = #{id}
    </delete>

    <insert id="insert" parameterType="com.scnu.entity.bus.BusCategory" useGeneratedKeys="true">
        insert into bus_category
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="id != null">id,</if>
            <if test="name != null">name,</if>
            <if test="img != null">img,</if>
            <if test="descr != null">descr,</if>
            <if test="content != null">content,</if>
            <if test="serviceType != null">service_type,</if>

        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="id != null">#{id},</if>
            <if test="name != null">#{name},</if>
            <if test="img != null">#{img},</if>
            <if test="descr != null">#{descr},</if>
            <if test="content != null">#{content},</if>
            <if test="serviceType != null">#{serviceType},</if>

        </trim>
    </insert>

    <update id="updateById" parameterType="com.scnu.entity.bus.BusCategory">
        update bus_category
        <set>
            <if test="name != null">
                name = #{name},
            </if>
            <if test="img != null">
                img = #{img},
            </if>
            <if test="descr != null">
                descr = #{descr},
            </if>
            <if test="content != null">
                content = #{content},
            </if>
            <if test="serviceType != null">
                service_type = #{serviceType},
            </if>
        </set>
        where id = #{id}
    </update>

</mapper>