<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xzj.mapper.bus.BusNewsMapper">

    <sql id="Base_Column_List">
        id,title,type,descr,content,cover,user,time
    </sql>

    <select id="selectAll" resultType="com.xzj.entity.bus.BusNews">
        select
        <include refid="Base_Column_List" />
        from bus_news
        <where>
            <if test="title != null"> and title like concat('%', #{title}, '%')</if>
            <if test="type != null"> and type = #{type}</if>
        </where>
        order by id desc
    </select>

    <select id="selectById" resultType="com.xzj.entity.bus.BusNews">
        select
        <include refid="Base_Column_List" />
        from bus_news
        where id = #{id}
    </select>

    <delete id="deleteById">
        delete from bus_news
        where  id = #{id}
    </delete>

    <insert id="insert" parameterType="com.xzj.entity.bus.BusNews" useGeneratedKeys="true" keyProperty="id">
        insert into bus_news
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="id != null">id,</if>
            <if test="title != null">title,</if>
            <if test="type != null">type,</if>
            <if test="descr != null">descr,</if>
            <if test="content != null">content,</if>
            <if test="cover != null">cover,</if>
            <if test="user != null">user,</if>
            <if test="time != null">time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="id != null">#{id},</if>
            <if test="title != null">#{title},</if>
            <if test="type != null">#{type},</if>
            <if test="descr != null">#{descr},</if>
            <if test="content != null">#{content},</if>
            <if test="cover != null">#{cover},</if>
            <if test="user != null">#{user},</if>
            <if test="time != null">#{time},</if>
        </trim>
    </insert>

    <update id="updateById" parameterType="com.xzj.entity.bus.BusNews">
        update bus_news
        <set>
            <if test="title != null">
                title = #{title},
            </if>
            <if test="type != null">
                type = #{type},
            </if>
            <if test="descr != null">
                descr = #{descr},
            </if>
            <if test="content != null">
                content = #{content},
            </if>
            <if test="cover != null">
                cover = #{cover},
            </if>
            <if test="user != null">
                user = #{user},
            </if>
            <if test="time != null">
                time = #{time},
            </if>
        </set>
        where id = #{id}
    </update>

    <select id="selectTopNews" resultType="com.xzj.entity.bus.BusNews">
        select
        <include refid="Base_Column_List" />
        from bus_news order by time desc
        limit 8
    </select>

</mapper>