<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.scnu.mapper.system.SysMenuMapper">
    <sql id="Base_Column_List">
        menu_id,route_name,menu_name,label,parent_id,order_num,path,component,menu_type,status,icon,create_by,create_time,remark
    </sql>

    <insert id="add" parameterType="com.scnu.entity.system.SysMenu" useGeneratedKeys="true">
        insert into sys_menu
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="menuId != null">menu_id,</if>
            <if test="routeName != null">route_name,</if>
            <if test="menuName != null">menu_name,</if>
            <if test="label != null">label,</if>
            <if test="parentId != null">parent_id,</if>
            <if test="orderNum != null">order_num,</if>
            <if test="path != null">path,</if>
            <if test="component != null">component,</if>
            <if test="menuType != null">menu_type,</if>
            <if test="status != null">status,</if>
            <if test="icon != null">icon,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="remark != null">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="menuId != null">#{menuId},</if>
            <if test="routeName != null">#{routeName},</if>
            <if test="menuName != null">#{menuName},</if>
            <if test="label != null">#{label},</if>
            <if test="parentId != null">#{parentId},</if>
            <if test="orderNum != null">#{orderNum},</if>
            <if test="path != null">#{path},</if>
            <if test="component != null">#{component},</if>
            <if test="menuType != null">#{menuType},</if>
            <if test="status != null">#{status},</if>
            <if test="icon != null">#{icon},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>

    <update id="updateById" parameterType="com.scnu.entity.system.SysMenu">
        update sys_menu
        <set>
            <if test="routeName != null">
                route_name = #{routeName},
            </if>
            <if test="menuName != null">
                menu_name = #{menuName},
            </if>
            <if test="label != null">
                label = #{label},
            </if>
            <if test="parentId != null">
                parent_id = #{parentId},
            </if>
            <if test="orderNum != null">
                order_num = #{orderNum},
            </if>
            <if test="path != null">
                path = #{path},
            </if>
            <if test="component != null">
                component = #{component},
            </if>
            <if test="menuType != null">
                menu_type = #{menuType},
            </if>
            <if test="status != null">
                status = #{status},
            </if>
            <if test="icon != null">
                icon = #{icon},
            </if>
            <if test="createBy != null">
                create_by = #{createBy},
            </if>
            <if test="createTime != null">
                create_time = #{createTime},
            </if>
            <if test="remark != null">
                remark = #{remark},
            </if>
        </set>
        where menu_id = #{menuId}
    </update>

    <delete id="deleteById">
        delete from sys_menu
        where  menu_id = #{menuId}
    </delete>

    <select id="selectById" resultType="com.scnu.entity.system.SysMenu">
        select
        <include refid="Base_Column_List" />
        from sys_menu
        where menu_id = #{menuId}
    </select>

    <select id="selectByParentId" resultType="com.scnu.entity.system.SysMenu">
        select
        <include refid="Base_Column_List" />
        from sys_menu
        where parent_id = #{parentId}
    </select>

    <select id="selectAll" resultType="com.scnu.entity.system.SysMenu">
        select
        <include refid="Base_Column_List" />
        from sys_menu
        <where>
            <if test="menuId != null"> and menu_id = #{menuId}</if>
            <if test="menuName != null"> and menu_name like concat('%', #{menuName}, '%')</if>
            <if test="label != null"> and label like concat('%', #{label}, '%')</if>
            <if test="parentId != null"> and parent_id = #{parentId}</if>
            <if test="status != null"> and status = #{status}</if>
        </where>
        order by parent_id, order_num
    </select>

    <!--查询用户权限-->
    <select id="selectMenuList" resultType="com.scnu.entity.system.SysMenu">
        select distinct m.*
        from sys_user u
        inner join sys_user_role ur on u.user_id = ur.user_id
        inner join sys_role_menu rm on ur.role_id = rm.role_id
        inner join sys_menu m on m.menu_id = rm.menu_id
        where u.user_id = #{userId} and m.status = '0'
        <if test="parentId != null">
            and m.parent_id = #{parentId}
        </if>
        <if test="label != null and label != ''">
            and m.label like CONCAT('%', #{label}, '%')
        </if>
    </select>

    <select id="selectDirMenuList" resultType="com.scnu.entity.system.SysMenuSimple">
        select distinct m.label, concat(m.menu_id, '') as menu_id, concat(m.parent_id, '') as parent_id
        from sys_menu m
        where m.menu_type = 'M' and m.status = '0'
    </select>
</mapper>