<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xzj.mapper.system.SysLoginMapper">
    <sql id="Base_Column_List">
        id,user_name,login_addr,login_time
    </sql>


    <insert id="add" parameterType="com.xzj.entity.system.SysLogin" useGeneratedKeys="true">
        insert into sys_login
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="id != null">id,</if>
            <if test="userName != null">user_name,</if>
            <if test="loginTime != null">login_time,</if>
            <if test="loginAddr != null">login_addr,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="id != null">#{id},</if>
            <if test="userName != null">#{userName},</if>
            <if test="loginTime != null">#{loginTime},</if>
            <if test="loginAddr != null">#{loginAddr},</if>
        </trim>
    </insert>

    <delete id="deleteById">
        delete from sys_login
        where  id = #{id}
    </delete>

    <select id="selectById" resultType="com.xzj.entity.system.SysLogin">
        select
        <include refid="Base_Column_List" />
        from sys_login
        where id = #{id}
    </select>

    <select id="selectAll" resultType="com.xzj.entity.system.SysLogin">
        select
        <include refid="Base_Column_List" />
        from sys_login
        <where>
            <if test="userName != null"> and user_name = #{roleName}</if>
            <if test="loginTime != null"> and login_time like concat(#{loginTime},'%')</if>
        </where>
        order by id
    </select>
</mapper>